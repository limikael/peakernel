{
	"include": ["Fs.h","Arduino.h","QuickjsEngine.h","InfoRecord.h"],
	"classes": {
		"Fs": {
			"constructible": false,
			"methods": {
				"open": {"return": "FileHandle","args":["string","string"]}
			}
		},
		"FileHandle": {
			"methods": {
				"close": {},
				"write": {"args": ["buffer"]}
			},
			"events": {
				"data": {"args": ["buffer"], "dispatcher": "dataEvent"},
				"close": {"dispatcher": "closeEvent"}
			}
		},
		"StringArray": {
			"methods": {
				"size": {"return": "int"},
				"at": {"return": "string", "args": ["int"]}
			}
		},
		"InfoRecord": {
			"methods": {
				"getString": {"args": ["string"], "return": "string"},
				"getInt": {"args": ["string"], "return": "int"},
				"getType": {"args": ["string"], "return": "string"},
				"getKeys": {"return": "StringArray"}
			}
		}
	},
	"functions": {
		"getFsInstance": {"return": "Fs"},
		"scheduleRestart": {},
		"collectInfo": {"return": "InfoRecord"}
	}
}
