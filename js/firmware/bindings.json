{
	"include": ["Fs.h","InfoRecord.h","encoding.h"],
	"classes": {
		"Fs": {
			"constructible": false,
			"methods": {
				"open": {"return": "FileHandle","args":["string","string"]},
				"getInstance": {"return": "Fs", "static": true}
			}
		},
		"FileHandle": {
			"constructible": false,
			"methods": {
				"close": {},
				"write": {"args": ["buffer"]},
				"setDataEventSize": {"args": ["int"]},
				"getDataWriteAdviceSize": {"return": "int"},
				"isClosed": {"return": "int"},
				"isClosing": {"return": "int"}
			},
			"events": {
				"data": {"args": ["buffer"], "dispatcher": "dataEvent"},
				"close": {"dispatcher": "closeEvent"},
				"drain": {"dispatcher": "drainEvent"}
			}
		},
		"StringArray": {
			"methods": {
				"size": {"return": "int"},
				"at": {"return": "string", "args": ["int"]}
			}
		},
		"InfoRecord": {
			"methods": {
				"getString": {"args": ["string"], "return": "string"},
				"getInt": {"args": ["string"], "return": "int"},
				"getType": {"args": ["string"], "return": "string"},
				"getKeys": {"return": "StringArray"}
			}
		},
		"InfoCollector": {
			"constructible": false,
			"methods": {
				"collectInfo": {"return": "InfoRecord"},
				"getInstance": {"return": "InfoCollector", "static": true}
			}
		}
	},
	"functions": {
		"encodeBase64": {"args": ["buffer"], "return": "string"},
		"decodeBase64": {"args": ["string"], "return": "buffer"},
		"encodeAscii": {"args": ["string"], "return": "buffer"},
		"decodeAscii": {"args": ["buffer"], "return": "string"},
	}
}
